  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'Information


    DP - Draw Phase. Draw one card.

    MP - Main Phase.
    Play one card.

    BP - Battle Phase. Choose a card to battle another.

    Grid
    layout - Top two rows are the opponents field, bottom two rows are your field.

    Summon
    - Card to be played your top row.

    Sorcery/Hex - Card to be played in your
    bottom row. (Not yet implemented)

    Attack - Plays card vertical. If you
    attack opponents card deal the difference of your cards power and opponents guard
    to the opponents HP.

    Defense - Plays card horizontal. If opponents summon
    attacks and has less power than the card, deal the difference to the opponents
    HP. You will not take battle damage when attacked.

    Element - When the corresponding
    effect card is played, boosts the power/guard of the summon. (Not yet implemented)

    Rank
    - The amount of summon needed to be sacrificed in order to play the card. (Not
    yet implemented)

    Power - Red value on the bottom left of the card. This
    shows the attack of the card.

    Guard - Blue value on the bottom right of
    the card. This shows the HP of the card.

    Debug - Continues to the next
    phase if stuck.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
